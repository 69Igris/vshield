# =====================================================
# Database
# =====================================================
# MongoDB Atlas connection string.
# Get this from: https://cloud.mongodb.com -> Cluster -> Connect -> Drivers
# Make sure the database name "bgv" is at the end of the URL.
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/bgv?retryWrites=true&w=majority"

# =====================================================
# Auth
# =====================================================
JWT_SECRET="change_me_to_a_long_random_string"
JWT_EXPIRES_IN="7d"

# =====================================================
# Server
# =====================================================
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS allow-list)
FRONTEND_URL="http://localhost:3000"

# =====================================================
# Verification provider URLs
# =====================================================
# In production these point at a licensed provider (Karza, Surepass, IDfy, etc.).
# For the assignment, both point at our own mock endpoints inside the backend.
AADHAAR_API_URL="http://localhost:5000/mock-api/aadhaar/verify"
PAN_API_URL="http://localhost:5000/mock-api/pan/verify"

# =====================================================
# Cloudinary (report storage)
# =====================================================
# Sign up at https://cloudinary.com (free tier is plenty).
# Dashboard -> "Product Environment Credentials" gives you these three values.
# If any of these are blank, the backend just skips cloud upload and still
# streams the PDF normally on download.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER="bgv-reports"

# =====================================================
# Optional: AWS S3 (not used — Cloudinary is the active file store)
# =====================================================
# AWS_BUCKET_NAME=
